[Unit]
Description=Coe dictation daemon
Documentation=https://github.com/quailyquaily/coe
Wants=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/coe serve
Restart=on-failure
RestartSec=2
Environment=XDG_RUNTIME_DIR=%t
EnvironmentFile=-%h/.config/coe/env

[Install]
WantedBy=default.target
